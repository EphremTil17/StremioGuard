#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

INSTALL_MISSING_DEPS="${INSTALL_MISSING_DEPS:-1}"
UV_INSTALL_DIR="${UV_INSTALL_DIR:-$HOME/.local/bin}"

ensure_uv() {
    if command -v uv >/dev/null 2>&1; then
        return 0
    fi

    case ":${PATH}:" in
        *":${UV_INSTALL_DIR}:"*) ;;
        *) export PATH="${UV_INSTALL_DIR}:${PATH}" ;;
    esac
    if command -v uv >/dev/null 2>&1; then
        return 0
    fi

    if [[ "${INSTALL_MISSING_DEPS}" != "1" ]]; then
        echo "uv is required but not installed and INSTALL_MISSING_DEPS=0." >&2
        echo "Install it with: curl -LsSf https://astral.sh/uv/install.sh | sh" >&2
        return 1
    fi

    if ! command -v curl >/dev/null 2>&1; then
        echo "curl is required to bootstrap uv but is not installed." >&2
        echo "Install curl, or install uv manually: https://docs.astral.sh/uv/" >&2
        return 1
    fi

    echo "uv is missing; installing via the official installer to ${UV_INSTALL_DIR}." >&2
    if ! curl -LsSf https://astral.sh/uv/install.sh | sh; then
        echo "uv installation failed." >&2
        echo "Install it manually: curl -LsSf https://astral.sh/uv/install.sh | sh" >&2
        return 1
    fi

    case ":${PATH}:" in
        *":${UV_INSTALL_DIR}:"*) ;;
        *) export PATH="${UV_INSTALL_DIR}:${PATH}" ;;
    esac

    if ! command -v uv >/dev/null 2>&1; then
        echo "uv installed but is not on PATH (looked in ${UV_INSTALL_DIR})." >&2
        echo "Add it to PATH and rerun, or pass UV_INSTALL_DIR=/path/to/bin." >&2
        return 1
    fi
}

ensure_uv
exec uv --cache-dir "$ROOT_DIR/.uv-cache" run python -m stremioguard.cli "$@"
