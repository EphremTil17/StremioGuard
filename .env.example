VPN_SERVICE_PROVIDER=nordvpn
VPN_TYPE=wireguard

# --- NordVPN WireGuard ---
# Recommended for performance. If you do not already have a WireGuard key, the
# guided setup can still extract it through the host NordVPN CLI as a fallback.
#   sudo apt install wireguard-tools
#   nordvpn set technology nordlynx
#   nordvpn connect
#   sudo wg show nordlynx private-key
#   nordvpn disconnect
WIREGUARD_PRIVATE_KEY=<paste-key-here>
WIREGUARD_ADDRESSES=10.5.0.2/32

# --- NordVPN OpenVPN ---
# Alternative path if you prefer service credentials over WireGuard.
OPENVPN_USER=<paste-service-username-here>
OPENVPN_PASSWORD=<paste-service-password-here>

SERVER_REGIONS=United States
# SERVER_CITIES=
# SERVER_COUNTRIES=United States
# SERVER_HOSTNAMES=us1234.nordvpn.com

FIREWALL=on
# FIREWALL_OUTBOUND_SUBNETS=192.168.1.0/24

TZ=America/Chicago

# --- Optional Stremio server tweaks ---
# Keep our compatibility patch bundle enabled unless you deliberately want the
# upstream image behavior back. Turning this off removes the HTTPS redirect fix,
# the local self-probe rewrite, the favicon guard, and the /casting stub.
STREMIO_APPLY_PATCHES=1
#
# CASTING_DISABLED=1 silences SSDP "EPERM 239.255.255.250:1900" log noise from
# gluetun's firewall correctly dropping outbound multicast. Our local image
# keeps a stub /casting endpoint alive in that mode so the Stremio web client
# sees an empty device list instead of a false "streaming server might be
# offline" warning.
CASTING_DISABLED=1

# --- Optional log-noise reduction ---
# Skip repeated /device-info hardware-acceleration probe runs. This does not
# change playback behavior; it only prevents the server from re-testing qsv,
# nvenc, and vaapi on every reconnect when no profile is configured.
STREMIO_SKIP_HW_PROBE=1

# Bind address for the Stremio streaming port (gluetun publishes 11470). All
# three deployment tiers in docs/secure-access.md use this host's LAN IP:
#   <LAN-IP>    e.g. 10.168.77.10 — find with `ip -4 addr show` or `hostname -I`
#   0.0.0.0     binds on every NIC; only needed on multi-homed hosts
#   127.0.0.1   loopback; makes Stremio unreachable from LAN/Tailscale and is
#               present here only as a fail-safe default for unconfigured runs
# `./stremio init` walks you through this; existing setups upgrading from
# <= v0.2.0 must add HOST_BIND_ADDR=<your-LAN-IP> to .env before pulling, or
# the streaming port will fall back to loopback and stop accepting LAN traffic.
HOST_BIND_ADDR=127.0.0.1

# Public origin clients use to reach Stremio. Set in Tier 2/3 (reverse-proxied
# behind a domain) to e.g. https://stremio.example.com. Leave blank in Tier 1
# (LAN + Tailscale only) — Stremio will use whatever host:port the client
# actually connected to, such as http://<host-LAN-IP>:11470.
EXTERNAL_BASE_URL=

# Private loopback origin the server should use for ffprobe and HLS self-
# references instead of going back out through the public reverse proxy.
INTERNAL_MEDIA_BASE_URL=http://127.0.0.1:11470

# Watchdog poll cadence stays tight for safety; summary log cadence stays slower
# to avoid flooding logs during healthy steady-state runs.
# WATCH_INTERVAL_SECONDS=10
# WATCHDOG_LOG_INTERVAL_SECONDS=300

# --- Future providers (uncomment to switch) ---
# VPN_SERVICE_PROVIDER=mullvad
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=
# WIREGUARD_ADDRESSES=10.64.x.x/32
# SERVER_CITIES=New York
