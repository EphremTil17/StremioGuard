[Unit]
Description=Guard Stremio behind the gluetun VPN container
After=default.target

[Service]
Type=simple
WorkingDirectory=%h/projects/stremio
ExecStart=%h/.local/bin/uv --cache-dir %h/projects/stremio/.uv-cache run python %h/projects/stremio/bin/stremio-vpn watchdog
Restart=always
RestartSec=10

[Install]
WantedBy=default.target
